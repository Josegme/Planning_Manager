{
  "name": "planning-manager",
  "version": "1.0.0",
  "description": "Planning Manager - Aplicación Desktop para Organizadores de Eventos",
  "main": "main/dist/main.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "tsc -p main/tsconfig.json && npm run copy:preload && electron .",
    "dev:renderer": "cd renderer && npm run dev",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p main/tsconfig.json && npm run copy:preload",
    "build:renderer": "cd renderer && npm run build",
    "copy:preload": "node -e \"const fs = require('fs'); const path = require('path'); const src = path.join(__dirname, 'main', 'preload.js'); const dest = path.join(__dirname, 'main', 'dist', 'preload.js'); if (!fs.existsSync(path.dirname(dest))) fs.mkdirSync(path.dirname(dest), { recursive: true }); fs.copyFileSync(src, dest);\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "event-management",
    "desktop"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.planningmanager.app",
    "productName": "Planning Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/dist/**",
      "renderer/dist/**",
      "package.json"
    ],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["es"]
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/xlsx": "^0.0.36",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^9.2.2",
    "express": "^4.18.2",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  }
}
